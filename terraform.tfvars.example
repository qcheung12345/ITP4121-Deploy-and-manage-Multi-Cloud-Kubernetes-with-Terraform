# Azure deployment
enable_azure            = false
azure_subscription_id   = "<your-azure-subscription-id>"
azure_resource_group_name = "itp4121-azure-rg"

# GCP deployment
# Enable only after GCP credentials are configured.
enable_gcp              = false
gcp_project_id          = "<your-gcp-project-id>"
gcp_enable_managed_postgres = false
gcp_postgres_authorized_cidr = "<your-public-ip-cidr>"

# Kubernetes secrets and TLS (Terraform-managed)
enable_k8s_secrets      = false
# Optional: set only when multiple kubeconfig contexts exist.
# kubeconfig_context    = "your-context"
# Required before production deployment
app_secret_key          = "replace-with-strong-secret"
